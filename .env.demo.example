IG_ENV=DEMO
IG_API_KEY=
IG_USERNAME=
IG_PASSWORD=
IG_ACCOUNT_ID=
IG_ACC_TYPE=DEMO
IG_REST_BASE_URL=https://demo-api.ig.com/gateway/deal
IG_STREAMING_ENABLED=true
IG_STREAMING_MODE=PRICE
IG_MARKET_SEARCH_TERM=USD/JPY
IG_MARKET_EPIC=
IG_ORDER_EXECUTION_ENABLED=false
IG_DRY_RUN_ONLY=true
IG_LOG_LEVEL=INFO

IG_USE_SESSION_VERSION=2
IG_STREAM_PRICE_FIELDS=BIDPRICE1,ASKPRICE1,TIMESTAMP,DELAY,DLG_FLAG,HIGH,LOW,MID_OPEN
IG_STREAM_CHART_TICK_FIELDS=BID,OFR,LTP,UTM
# Leave blank for normal decimal quotes. Set only after confirming scaled broker stream values.
IG_PRICE_SCALE_DIVISOR=
IG_TICK_OUTPUT_PATH=data/live_demo_ticks/usdjpy
IG_AUDIT_OUTPUT_PATH=reports/ig_demo_audit
IG_TOKEN_CACHE_ENABLED=false
IG_TOKEN_CACHE_PATH=.runtime/ig_demo_session.json
