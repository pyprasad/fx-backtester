IG_ENV=DEMO
IG_API_KEY=
IG_USERNAME=
IG_PASSWORD=
IG_ACCOUNT_ID=
IG_ACC_TYPE=DEMO
IG_REST_BASE_URL=https://demo-api.ig.com/gateway/deal
IG_STREAMING_ENABLED=true
IG_STREAMING_MODE=PRICE
IG_MARKET_SEARCH_TERM=USD/JPY
IG_MARKET_EPIC=
IG_ORDER_EXECUTION_ENABLED=false
IG_DRY_RUN_ONLY=true
# For one explicitly confirmed DEMO execution-plumbing test only, temporarily invert both values:
# IG_ORDER_EXECUTION_ENABLED=true
# IG_DRY_RUN_ONLY=false
IG_LOG_LEVEL=INFO

IG_USE_SESSION_VERSION=2
IG_STREAM_PRICE_FIELDS=BIDPRICE1,ASKPRICE1,TIMESTAMP,DELAY,DLG_FLAG,HIGH,LOW,MID_OPEN
IG_STREAM_CHART_TICK_FIELDS=BID,OFR,LTP,UTM
# Leave blank for normal decimal quotes. Set only after confirming scaled broker stream values.
IG_PRICE_SCALE_DIVISOR=
IG_TICK_OUTPUT_PATH=data/live_demo_ticks/usdjpy
IG_AUDIT_OUTPUT_PATH=reports/ig_demo_audit
# Reuse CST/X-SECURITY-TOKEN across CLI commands to avoid repeated IG logins.
IG_TOKEN_CACHE_ENABLED=true
IG_TOKEN_CACHE_PATH=.runtime/ig_demo_session.json

# Optional temporary override for historical candle REST calls only.
# Streaming, accounts, positions, and orders still use IG_API_KEY/IG_USERNAME/IG_PASSWORD above.
# Use a separate token cache path so the sessions cannot be mixed.
IG_HISTORICAL_API_KEY=
IG_HISTORICAL_USERNAME=
IG_HISTORICAL_PASSWORD=
IG_HISTORICAL_ACCOUNT_ID=
IG_HISTORICAL_TOKEN_CACHE_ENABLED=true
IG_HISTORICAL_TOKEN_CACHE_PATH=.runtime/ig_demo_historical_session.json

# Optional strategy-level news guard overrides. Disabled by default so the selected strategy is
# unchanged unless these are explicitly set for research/demo validation.
# We don't have a mechanism to scrape the current week or month to use in the process, this needs to implement later.
NEWS_GUARD_ENABLED=false
NEWS_GUARD_CALENDAR_FILE=data/macro_calendar/usd_jpy_events_2022_2025_nasdaq.csv
NEWS_GUARD_BEFORE_MINUTES=60
NEWS_GUARD_AFTER_MINUTES=60

# Optional Telegram monitoring and control.
# Webhook URL path defaults to /telegram/<TELEGRAM_WEBHOOK_SECRET>.
# To reuse the exact path style from realtime_RSI, set TELEGRAM_WEBHOOK_PATH instead
# e.g. TELEGRAM_WEBHOOK_PATH=/telegram-webhook/prod-tg-secret-123
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ADMIN_USER_ID=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_PATH=
TELEGRAM_NOTIFY_TRADES=true
TELEGRAM_NOTIFY_SYSTEM=true
TELEGRAM_CONTROL_PATH=.runtime/ig_bot_control.json
TELEGRAM_STATUS_PATH=reports/ig_demo_audit/bot_run_usdjpy.json
